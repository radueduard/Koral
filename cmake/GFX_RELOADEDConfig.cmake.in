@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Public usage requirements that propagate from GFX_RELOADED::GFX_RELOADED.
# Consumers must have these vcpkg ports available (same toolchain/baseline as the framework).
find_dependency(glm CONFIG)
find_dependency(imgui CONFIG)
find_dependency(spdlog CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/GFX_RELOADEDTargets.cmake")

# The SDK may ship only a subset of build configs (typically Debug + Release). Map the Hub's
# other profiles (and any consumer build type) to the nearest config that is actually present,
# so find_package doesn't fail with "IMPORTED_IMPLIB not set" on RelWithDebInfo/MinSizeRel.
foreach(_gfx_target GFX_RELOADED::GFX_RELOADED GFX_RELOADED::Gfx_Runtime)
    if(TARGET ${_gfx_target})
        set_target_properties(${_gfx_target} PROPERTIES
            MAP_IMPORTED_CONFIG_RELWITHDEBINFO "RelWithDebInfo;Release;Debug"
            MAP_IMPORTED_CONFIG_MINSIZEREL     "MinSizeRel;Release;Debug"
            MAP_IMPORTED_CONFIG_RELEASE        "Release;Debug"
            MAP_IMPORTED_CONFIG_DEBUG          "Debug;Release")
    endif()
endforeach()

check_required_components(GFX_RELOADED)